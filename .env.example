# cesium ion access token for 3d globe visualization
# sign up at https://ion.cesium.com/ to get a free token
VITE_CESIUM_ION_TOKEN=your_token_here

# closed-network deployments: override every external map/terrain endpoint at
# build time. when unset, the frontend falls back to the cloud defaults
# (esri imagery, openstreetmap raster, cesium ion world terrain + ion satellite).
# see OPERATIONS.md "Closed-Network Deployment" for the full setup.

# 2d esri-style satellite imagery template, e.g. self-hosted tileserver-gl
# VITE_TILE_IMAGERY_URL=https://tiles.internal/imagery/{z}/{y}/{x}

# 2d reference labels overlay template
# VITE_TILE_REFERENCE_URL=https://tiles.internal/reference/{z}/{y}/{x}

# 2d osm raster template - also used by the 3d viewer's "map" terrain mode
# VITE_TILE_OSM_URL=https://tiles.internal/osm/{z}/{x}/{y}.png

# attribution string shown on the 2d satellite layer
# VITE_TILE_IMAGERY_ATTRIBUTION=Internal tile mirror

# 3d cesium terrain endpoint (e.g. cesium terrain builder output served locally)
# VITE_CESIUM_TERRAIN_URL=https://terrain.internal/world

# 3d cesium satellite imagery template (replaces ion asset 2 in 3d view)
# VITE_CESIUM_IMAGERY_URL=https://tiles.internal/imagery/{z}/{y}/{x}
