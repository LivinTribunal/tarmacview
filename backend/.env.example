# backend env overrides - copy to backend/.env (gitignored) and fill in secrets.
# every key here is also documented as a field on app.core.config.Settings.

# database
DATABASE_URL=postgresql://tarmacview:tarmacview@localhost:5432/tarmacview

# auth
# JWT_SECRET=change-me-in-production-minimum-256-bits
# JWT_EXPIRATION_MINUTES=15
# JWT_REFRESH_EXPIRATION_DAYS=7

# cors - JSON list of allowed origins
# CORS_ORIGINS=["http://localhost:5173"]

# openaip - required for the seeder to fetch the five default airports
# (LZIB / LZKZ / LZPP / etc.). without it the seeder logs the miss
# and leaves the airport tables empty.
# OPENAIP_API_KEY=

# default-user seeding - opt in for fresh dev installs only. the regen
# script (scripts/regenerate-db-seed.sh) sets SEED_USERS=true automatically.
# SEED_USERS=false
# SEED_ADMIN_EMAIL=admin@tmv.com
# SEED_ADMIN_PASSWORD=adminadmin
# SEED_COORDINATOR_EMAIL=coord@tmv.com
# SEED_COORDINATOR_PASSWORD=coordinator
# SEED_OPERATOR_EMAIL=operator@tmv.com
# SEED_OPERATOR_PASSWORD=operator

# deployment environment - "development" relaxes the jwt-default guard
# ENVIRONMENT=development

# elevation api fallback - per-point ground lookup for flat airports
# without a DEM. disabled by default so offline runs don't depend on
# outbound network. once a super admin saves the toggle in
# Super-admin -> System Settings, the DB-backed row wins over this var.
# ELEVATION_API_FALLBACK_ENABLED=false
# ELEVATION_API_LOOKUP_TIMEOUT=2.0

# fernet symmetric encryption key for admin-managed secrets at rest
# (currently the elevation_api_key column). accepts a 32-byte urlsafe-b64
# fernet key or any string (sha256-derived). unset is fine until a key
# is actually being written - the startup path is lazy.
# SECRET_ENCRYPTION_KEY=
