# stage 1: build
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG VITE_CESIUM_ION_TOKEN
ENV VITE_CESIUM_ION_TOKEN=$VITE_CESIUM_ION_TOKEN
# offline tile endpoints for the field build - empty by default = cloud defaults
ARG VITE_TILE_IMAGERY_URL
ARG VITE_TILE_OSM_URL
ARG VITE_TILE_REFERENCE_URL
ARG VITE_TILE_IMAGERY_ATTRIBUTION
ARG VITE_CESIUM_IMAGERY_URL
ENV VITE_TILE_IMAGERY_URL=$VITE_TILE_IMAGERY_URL
ENV VITE_TILE_OSM_URL=$VITE_TILE_OSM_URL
ENV VITE_TILE_REFERENCE_URL=$VITE_TILE_REFERENCE_URL
ENV VITE_TILE_IMAGERY_ATTRIBUTION=$VITE_TILE_IMAGERY_ATTRIBUTION
ENV VITE_CESIUM_IMAGERY_URL=$VITE_CESIUM_IMAGERY_URL
RUN npm run build

# stage 2: serve with nginx
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
